#include <bits/stdc++.h>
using namespace std;

using ll = long long;
const ll M=1e9+9,P=11;
ll pw[600005];

int main(){
    ios::sync_with_stdio(0);
    cin.tie(0);

    pw[0]=1;
    for(int i=1;i<600005;i++) pw[i]=pw[i-1]*P%M;

    int n,m; cin>>n>>m;
    unordered_set<ll> st;
    string s;

    auto H=[&](string &t){
        ll h=0;
        for(int i=0;i<t.size();i++)
            h=(h+t[i]*pw[i])%M;
        return h;
    };

    while(n--) cin>>s, st.insert(H(s));

    while(m--){
        cin>>s;
        ll h=H(s); bool ok=0;
        for(int i=0;i<s.size()&&!ok;i++){
            ll r=s[i]*pw[i]%M;
            for(char c:{'a','b','c'})
                if(c!=s[i]){
                    ll nh=(h-r+c*pw[i])%M;
                    if(nh<0) nh+=M;
                    if(st.count(nh)){ ok=1; break; }
                }
        }
        cout<<(ok?"YES\n":"NO\n");
    }
}
